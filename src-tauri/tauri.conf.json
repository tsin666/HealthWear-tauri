{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HealthWear",
  "version": "0.2.0",
  "identifier": "com.soyetsin.healthwear",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HealthWear 智能戒指",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
